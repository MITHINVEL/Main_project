rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /street_lights/{lightId} {
      // Create: only signed-in users
      allow create: if isSignedIn();

      // Read: ANY signed-in user can read ALL street lights
      // This allows SmsReceiver to query and match phone numbers
      allow read: if isSignedIn();

      // Update: ANY signed-in user (since all users in your app are owners)
      allow update: if isSignedIn();

      // Delete: ANY signed-in user (since all users in your app are owners)
      allow delete: if isSignedIn();
    }

    match /notifications/{notifId} {
      // MODIFIED: Allow any authenticated user to create notifications
      // This is critical for SMS receiver to create notifications
      allow create: if isSignedIn();

      // Read: owner or admin, OR legacy docs without createdBy (temporary)
      allow read: if isSignedIn() && (
        (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid) 
        || (resource.data.keys().hasAny(['userId']) && resource.data.userId == request.auth.uid)
        || isAdmin()
        || !resource.data.keys().hasAny(['createdBy'])
      );

      // Update: owner or admin, OR legacy docs without createdBy
      allow update: if isSignedIn() && (
        (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid) 
        || (resource.data.keys().hasAny(['userId']) && resource.data.userId == request.auth.uid)
        || isAdmin()
        || !resource.data.keys().hasAny(['createdBy'])
      );

      // Delete: allow users to delete their own notifications OR admin
      allow delete: if isSignedIn() && (
        (resource.data.keys().hasAny(['createdBy']) && resource.data.createdBy == request.auth.uid) 
        || (resource.data.keys().hasAny(['userId']) && resource.data.userId == request.auth.uid)
        || isAdmin()
        || !resource.data.keys().hasAny(['createdBy'])
      );
    }

    // NEW: SMS Messages collection for SMS notification service
    match /street_light_sms/{smsId} {
      // Allow any authenticated user to create SMS records
      allow create: if isSignedIn();
      
      // Read: any authenticated user can read
      allow read: if isSignedIn();
      
      // Update/Delete: any authenticated user
      allow update, delete: if isSignedIn();
    }

    match /users/{userId} {
      // user profile: only the owner can read/write their profile
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Default deny for any other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
